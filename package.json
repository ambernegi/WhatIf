{
  "name": "design-docs-poc",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "DOCUSAURUS_BASE_URL=/ docusaurus start",
    "start:poll": "DOCUSAURUS_BASE_URL=/ WATCHPACK_POLLING=true docusaurus start",
    "start:ghpages": "DOCUSAURUS_BASE_URL=/WhatIf/ docusaurus start",
    "start:ghpages:poll": "DOCUSAURUS_BASE_URL=/WhatIf/ WATCHPACK_POLLING=true docusaurus start",
    "build": "DOCUSAURUS_BASE_URL=/WhatIf/ docusaurus build",
    "build:local": "DOCUSAURUS_BASE_URL=/ docusaurus build",
    "serve": "DOCUSAURUS_BASE_URL=/WhatIf/ docusaurus serve",
    "serve:local": "DOCUSAURUS_BASE_URL=/ docusaurus serve",
    "deploy": "docusaurus deploy",
    "typecheck": "tsc --noEmit",
    "validate": "tsc --noEmit && docusaurus build"
  },
  "dependencies": {
    "@docusaurus/core": "^3.2.0",
    "@docusaurus/plugin-client-redirects": "^3.10.0",
    "@docusaurus/plugin-content-docs": "^3.2.0",
    "@docusaurus/preset-classic": "^3.2.0",
    "clsx": "^2.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@docusaurus/tsconfig": "^3.10.0",
    "typescript": "^6.0.2"
  }
}
